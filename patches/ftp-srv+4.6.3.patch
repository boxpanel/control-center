 const _ = require('lodash');
 const Promise = require('bluebird');
+const {TextDecoder} = require('util');
 
 const REGISTRY = require('./registry');
 
 const CMD_FLAG_REGEX = new RegExp(/^-(\w{1})$/);
 
+function scoreDecodedArg(text) {
+  const raw = String(text || '');
+  if (!raw) return -Infinity;
+  let score = 0;
+  score += (raw.match(/[\u4E00-\u9FFF]/g) || []).length * 8;
+  score += (raw.match(/[A-Za-z0-9._/\\:-]/g) || []).length * 2;
+  score -= (raw.match(/[\uFFFD]/g) || []).length * 12;
+  score -= (raw.match(/[^\u4E00-\u9FFFA-Za-z0-9._/\\:\-]/g) || []).length * 2;
+  return score;
+}
+
+function decodeCommandArg(text) {
+  const latin1 = String(text || '');
+  if (!latin1) return latin1;
+  const raw = Buffer.from(latin1, 'latin1');
+  const candidates = [];
+  try {
+    candidates.push(new TextDecoder('utf-8', {fatal: false}).decode(raw));
+  } catch {}
+  try {
+    candidates.push(new TextDecoder('gb18030', {fatal: false}).decode(raw));
+  } catch {}
+  candidates.push(latin1);
+  let best = latin1;
+  let bestScore = scoreDecodedArg(best);
+  for (const candidate of candidates) {
+    const score = scoreDecodedArg(candidate);
+    if (score > bestScore) {
+      best = candidate;
+      bestScore = score;
+    }
+  }
+  return best;
+}
